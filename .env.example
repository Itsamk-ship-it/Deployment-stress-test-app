# ---- Core ----
NODE_ENV=development
# Public base URL of the app (used for outgoing webhook callbacks, email links, etc.)
APP_URL=http://localhost:3000
PORT=3000

# ---- Auth ----
# 32+ char random secret used to sign session JWTs. CHANGE THIS in production.
AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ---- PostgreSQL ----
# Host port 5544 maps to the Postgres container (see docker-compose.yml), chosen
# to avoid colliding with anything already bound to 5432/5433.
DATABASE_URL=postgresql://postgres:postgres@localhost:5544/stresstest?schema=public

# ---- Redis (cache + job queue) ----
# Host port 6380 maps to the Redis container, avoiding a native Redis on 6379.
REDIS_URL=redis://localhost:6380

# ---- Email (SMTP) ----
# Leave SMTP_HOST empty to use a JSON "stream" transport that logs emails instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Stress Test <no-reply@stresstest.local>"

# ---- Webhooks ----
# Shared secret used to sign/verify incoming webhook payloads (HMAC-SHA256).
WEBHOOK_SECRET=change-me-webhook-secret

# ---- Uploads ----
# Directory where uploaded files are stored on disk (relative to project root).
UPLOAD_DIR=./uploads
# Max upload size in bytes (default 10MB).
MAX_UPLOAD_BYTES=10485760
